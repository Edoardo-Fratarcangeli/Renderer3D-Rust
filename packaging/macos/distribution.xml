<?xml version="1.0" encoding="utf-8"?>
<!-- macOS Installer wizard definition. The welcome/readme/conclusion panes are
     resolved per-language from resources/<lang>.lproj/ by productbuild. -->
<installer-gui-script minSpecVersion="2">
    <title>Rust 3D Renderer</title>

    <welcome    file="welcome.html"    mime-type="text/html"/>
    <readme     file="readme.html"     mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>
    <license    file="license.html"    mime-type="text/html"/>

    <options customize="never" require-scripts="false" hostArchitectures="arm64,x86_64"/>

    <choices-outline>
        <line choice="default">
            <line choice="tech.fratarcangeli.rendering3d"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="tech.fratarcangeli.rendering3d" visible="false">
        <pkg-ref id="tech.fratarcangeli.rendering3d"/>
    </choice>
    <pkg-ref id="tech.fratarcangeli.rendering3d" version="0">core.pkg</pkg-ref>
</installer-gui-script>
